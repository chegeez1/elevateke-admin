# ============================================================================
# ElevateKe — Environment Variables Reference
# ============================================================================
# Copy this file to .env for local development.
# In production, set these as environment secrets in your hosting platform.
# Never commit actual .env files to version control.
# ============================================================================

# ----------------------------------------------------------------------------
# Server
# ----------------------------------------------------------------------------

# Port the API server listens on (set automatically by Replit / your host)
PORT=8080

# Application environment: "development" or "production"
NODE_ENV=development

# Log verbosity: "trace" | "debug" | "info" | "warn" | "error" | "fatal"
LOG_LEVEL=info

# ----------------------------------------------------------------------------
# Database (PostgreSQL)
# ----------------------------------------------------------------------------

# Full PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/elevateke

# Individual connection parameters (used if DATABASE_URL is not set)
PGHOST=localhost
PGPORT=5432
PGDATABASE=elevateke
PGUSER=postgres
PGPASSWORD=your_db_password_here

# ----------------------------------------------------------------------------
# Security
# ----------------------------------------------------------------------------

# Secret used to sign JWT tokens — use a long random string (32+ chars)
# Generate: openssl rand -hex 32
SESSION_SECRET=change_me_to_a_long_random_string

# ----------------------------------------------------------------------------
# Admin Credentials
# ----------------------------------------------------------------------------

# Username and password for the admin dashboard login
# Change these before going to production!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_before_production

# ----------------------------------------------------------------------------
# Paystack (M-Pesa STK Push via Paystack)
# ----------------------------------------------------------------------------

# Your Paystack secret key — find it at dashboard.paystack.com → Settings → API
# Use the test key (sk_test_...) for development and live key (sk_live_...) for production
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key_here

# ----------------------------------------------------------------------------
# Resend (Transactional Email)
# ----------------------------------------------------------------------------

# Your Resend API key — get it at resend.com → API Keys
# Emails sent: welcome, deposit confirmed, payment failed, withdrawal status, reminders
RESEND_API_KEY=re_your_resend_api_key_here

# The "From" address for all outgoing emails.
# Must be a verified sender domain in your Resend account.
# Format: "Display Name <email@yourdomain.com>"
RESEND_FROM_EMAIL=ElevateKe <noreply@yourdomain.com>

# ----------------------------------------------------------------------------
# Platform URLs
# ----------------------------------------------------------------------------

# The base URL of the user-facing platform (used in email links and CTAs)
# No trailing slash. Example: https://elevateke.com
SITE_URL=http://localhost:21045

# ----------------------------------------------------------------------------
# Feature Flags / Tuning
# ----------------------------------------------------------------------------

# How many minutes before a pending deposit is considered expired (default: 30)
# Paystack STK Push expires after ~5 minutes, but allow extra time for slow networks
DEPOSIT_PENDING_TTL_MINUTES=30
